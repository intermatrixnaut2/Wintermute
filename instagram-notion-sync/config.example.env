# Copy this file to config.env and fill in the values.
# The launchd plist reads these directly — see setup instructions in README.

# ── Instagram ───────────────────────────────────────────────────────────────
# Extract from your browser after logging in to instagram.com.
# Open DevTools → Application → Cookies → https://www.instagram.com
#
# Refresh these whenever Instagram invalidates your session (typically 90 days).

IG_SESSION_ID=your_sessionid_cookie_value
IG_CSRF_TOKEN=your_csrftoken_cookie_value
IG_DS_USER_ID=your_ds_user_id_cookie_value

# ── Notion ───────────────────────────────────────────────────────────────────
# Create an integration at https://www.notion.so/my-integrations
# Share both databases with the integration.

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Instagram Saves database ID (from the database URL after the workspace slug)
NOTION_SAVES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Content Ideas database ID (used only by ideate.py)
NOTION_IDEAS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Claude API (ideate.py only) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
